{
    "files.autoSave": "onFocusChange",
    "editor.formatOnSave": true,
    "[lua]": {
        "editor.defaultFormatter": "JohnnyMorganz.stylua",
        // Or if using LuaFormat: "editor.defaultFormatter": "koihik.vscode-lua-format",
        "editor.formatOnSave": true
    },
    "stylua.searchParentDirectories": true,
    "achilleshr.runonsave": {
        "autoSave": true,
        "onSave": true,
        "commands": [
            {
                "match": ".*\\.lua$",
                "isAsync": false,
                "cmd": "${workspaceFolder}/BundleAndDeploy.bat",
                "autoShowOutputPanel": "always"
            }
        ]
    },
    "emeraldwalk.runonsave": {
        "autoSave": true,
        "commands": [
            {
                "match": ".*\\.lua$",
                "isAsync": false,
                "cmd": "${workspaceFolder}/BundleAndDeploy.bat",
                "autoShowOutputPanel": "always"
            }
        ]
    },
    "stylua.targetReleaseVersion": "latest"
}